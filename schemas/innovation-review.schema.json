{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/arthas-sws/3DGScompresion_paper/schemas/innovation-review.schema.json",
  "title": "3DGS Innovation Review Extension",
  "type": "object",
  "required": [
    "schema_version",
    "paper",
    "source_pack_path",
    "review_depth",
    "index_card",
    "innovation_claims",
    "claim_evidence_matrix",
    "experiment_tables",
    "experiment_audit",
    "novelty_assessment",
    "improvement_ideas",
    "proposed_experiments",
    "related_papers",
    "validation"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.1" },
    "source_pack_path": { "type": "string", "minLength": 1 },
    "review_depth": { "enum": ["preliminary", "deep"] },
    "paper": {
      "type": "object",
      "required": ["id", "title", "pdf_path"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "pattern": "^P[0-9]{3,}$" },
        "title": { "type": "string", "minLength": 1 },
        "authors": { "type": "array", "items": { "type": "string" } },
        "arxiv_id": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "pdf_path": { "type": "string", "minLength": 1 },
        "pdf_hash": { "type": ["string", "null"], "pattern": "^[A-Fa-f0-9]{32,128}$" },
        "paper_version": { "type": ["string", "null"] },
        "code_commit": { "type": ["string", "null"] },
        "analysis_scope": { "type": "string" }
      }
    },
    "index_card": {
      "type": "object",
      "required": ["task", "method_tags", "innovation_tags", "one_sentence_takeaway", "report_path", "analysis_json_path", "innovation_review_path"],
      "additionalProperties": true,
      "properties": {
        "task": { "type": "string" },
        "method_tags": { "type": "array", "items": { "type": "string" } },
        "innovation_tags": { "type": "array", "items": { "type": "string" } },
        "compression_targets": { "type": "array", "items": { "type": "string" } },
        "main_metrics": { "type": "array", "items": { "type": "string" } },
        "datasets": { "type": "array", "items": { "type": "string" } },
        "one_sentence_takeaway": { "type": "string" },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "report_path": { "type": "string" },
        "analysis_json_path": { "type": "string" },
        "innovation_review_path": { "type": "string" }
      }
    },
    "innovation_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "title",
          "author_claim",
          "interpretation",
          "method_location",
          "code_location",
          "evidence_ids",
          "counter_evidence_ids",
          "support_level",
          "missing_evidence",
          "closest_prior_work",
          "differentiators",
          "confidence"
        ],
        "additionalProperties": true,
        "properties": {
          "claim_id": { "type": "string", "pattern": "^C[0-9]+$" },
          "title": { "type": "string", "minLength": 1 },
          "author_claim": { "type": "string" },
          "interpretation": { "type": "string" },
          "method_location": { "type": "array", "items": { "type": "string" } },
          "code_location": { "type": "array", "items": { "type": "string" } },
          "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "counter_evidence_ids": { "type": "array", "items": { "type": "string" } },
          "support_level": { "enum": ["direct", "partial", "indirect", "none", "conflict"] },
          "missing_evidence": { "type": "array", "items": { "type": "string" } },
          "closest_prior_work": { "type": "array", "items": { "type": "string" } },
          "differentiators": { "type": "array", "items": { "type": "string" } },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    },
    "claim_evidence_matrix": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "theory", "main_results", "ablation", "efficiency", "failure_cases", "code", "final_judgment"],
        "additionalProperties": false,
        "properties": {
          "claim_id": { "type": "string", "pattern": "^C[0-9]+$" },
          "theory": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "main_results": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "ablation": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "efficiency": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "failure_cases": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "code": { "enum": ["直接", "部分", "间接", "无", "冲突"] },
          "final_judgment": { "type": "string" }
        }
      }
    },
    "experiment_tables": { "type": "array", "items": { "type": "object" } },
    "experiment_audit": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["claim_id", "support_level", "reasoning", "evidence_ids", "missing_evidence"],
        "additionalProperties": true,
        "properties": {
          "claim_id": { "type": "string", "pattern": "^C[0-9]+$" },
          "support_level": { "enum": ["direct", "partial", "indirect", "none", "conflict"] },
          "reasoning": { "type": "string" },
          "evidence_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "missing_evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "novelty_assessment": {
      "type": "object",
      "required": ["scope", "closest_prior_work", "overlap", "differentiators", "evidence_limitations", "confidence", "conclusion"],
      "additionalProperties": true,
      "properties": {
        "scope": { "type": "string" },
        "closest_prior_work": { "type": "array", "items": { "type": "string" } },
        "overlap": { "type": "array", "items": { "type": "string" } },
        "differentiators": { "type": "array", "items": { "type": "string" } },
        "evidence_limitations": { "type": "array", "items": { "type": "string" } },
        "confidence": { "enum": ["low", "medium", "high"] },
        "conclusion": { "type": "string" }
      }
    },
    "improvement_ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["idea_id", "idea", "targets_claim", "research_value", "implementation_cost", "failure_risk", "required_resources", "minimum_validation", "priority", "evidence_ids"],
        "additionalProperties": true,
        "properties": {
          "idea_id": { "type": "string", "pattern": "^I[0-9]+$" },
          "idea": { "type": "string" },
          "targets_claim": { "type": "string", "pattern": "^(C[0-9]+|general)$" },
          "research_value": { "enum": ["high", "medium", "low"] },
          "implementation_cost": { "enum": ["high", "medium", "low"] },
          "failure_risk": { "enum": ["high", "medium", "low"] },
          "required_resources": { "type": "array", "items": { "type": "string" } },
          "minimum_validation": { "type": "string" },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "evidence_ids": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "proposed_experiments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["experiment_id", "claim_id", "goal", "hypothesis", "independent_variables", "control_baselines", "datasets", "metrics", "implementation_steps", "expected_result", "failure_interpretation", "estimated_cost", "priority"],
        "additionalProperties": true,
        "properties": {
          "experiment_id": { "type": "string", "pattern": "^X[0-9]+$" },
          "claim_id": { "type": "string", "pattern": "^(C[0-9]+|general)$" },
          "goal": { "type": "string" },
          "hypothesis": { "type": "string" },
          "independent_variables": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "control_baselines": { "type": "array", "items": { "type": "string" } },
          "datasets": { "type": "array", "items": { "type": "string" } },
          "metrics": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "implementation_steps": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "expected_result": { "type": "string" },
          "failure_interpretation": { "type": "string" },
          "estimated_cost": { "enum": ["low", "medium", "high"] },
          "priority": { "enum": ["P0", "P1", "P2"] }
        }
      }
    },
    "related_papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "relation_type", "read_depth", "similarity_summary", "similarity_level", "local_match_status", "used_for_claims", "evidence"],
        "additionalProperties": true,
        "properties": {
          "title": { "type": "string" },
          "relation_type": { "enum": ["baseline_in_experiments", "similar_innovation", "transfer_candidate"] },
          "read_depth": { "enum": ["full_read", "targeted_read", "metadata_only"] },
          "similarity_summary": { "type": "string" },
          "similarity_level": { "enum": ["high", "medium", "low", "unclear"] },
          "local_match_status": { "enum": ["matched", "not_found", "retrieval_requested", "not_checked"] },
          "local_path": { "type": ["string", "null"] },
          "used_for_claims": { "type": "array", "items": { "type": "string", "pattern": "^C[0-9]+$" } },
          "evidence": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "related_paper_request_path": { "type": ["string", "null"] },
    "validation": {
      "type": "object",
      "required": ["language", "status", "warnings", "missing_sections"],
      "additionalProperties": true,
      "properties": {
        "language": { "const": "zh-CN" },
        "status": { "enum": ["PASS", "WARN", "FAIL"] },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "missing_sections": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
