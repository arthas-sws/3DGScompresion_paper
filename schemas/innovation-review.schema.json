{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/3dgs/innovation-review.schema.json",
  "title": "3DGS Deep Paper Review",
  "type": "object",
  "required": [
    "schema_version",
    "paper",
    "index_card",
    "innovation_claims",
    "experiment_tables",
    "experiment_audit",
    "improvement_ideas",
    "proposed_experiments",
    "related_papers",
    "validation"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "paper": {
      "type": "object",
      "required": ["id", "title", "pdf_path"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "authors": { "type": "array", "items": { "type": "string" } },
        "year": { "type": ["integer", "string", "null"] },
        "venue_or_arxiv": { "type": ["string", "null"] },
        "arxiv_id": { "type": ["string", "null"] },
        "doi": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] },
        "pdf_path": { "type": "string" },
        "pdf_hash": { "type": ["string", "null"] },
        "analysis_scope": { "type": "string" }
      },
      "additionalProperties": true
    },
    "index_card": {
      "type": "object",
      "required": ["task", "method_tags", "innovation_tags", "one_sentence_takeaway", "report_path", "json_path"],
      "properties": {
        "task": { "type": "string" },
        "method_tags": { "type": "array", "items": { "type": "string" } },
        "innovation_tags": { "type": "array", "items": { "type": "string" } },
        "compression_targets": { "type": "array", "items": { "type": "string" } },
        "main_metrics": { "type": "array", "items": { "type": "string" } },
        "datasets": { "type": "array", "items": { "type": "string" } },
        "one_sentence_takeaway": { "type": "string" },
        "best_use_for_future_reading": { "type": ["string", "null"] },
        "open_questions": { "type": "array", "items": { "type": "string" } },
        "report_path": { "type": "string" },
        "json_path": { "type": "string" }
      },
      "additionalProperties": true
    },
    "innovation_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "claim", "evidence"],
        "properties": {
          "claim_id": { "type": "string" },
          "claim": { "type": "string" },
          "author_claim": { "type": ["string", "null"] },
          "interpretation": { "type": ["string", "null"] },
          "method_components": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "experiment_tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table_id", "evidence", "extraction_status", "columns", "rows"],
        "properties": {
          "table_id": { "type": "string" },
          "caption": { "type": ["string", "null"] },
          "evidence": { "type": "string" },
          "source_page": { "type": ["integer", "string", "null"] },
          "extraction_status": { "enum": ["verified", "auto_failed", "manual_transcription", "partial", "not_applicable"] },
          "entry_method": { "enum": ["automatic", "manual_transcription", "mixed", "not_applicable"] },
          "columns": { "type": "array", "items": { "type": "string" } },
          "rows": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "uncertain_cells": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "experiment_audit": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "support_level", "evidence"],
        "properties": {
          "claim_id": { "type": "string" },
          "support_level": { "enum": ["directly_supported", "partially_supported", "weakly_supported", "not_tested", "unclear"] },
          "reasoning": { "type": "string" },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "missing_evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "improvement_ideas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["idea", "category", "targets_claim", "experiment_to_validate", "evidence_basis"],
        "properties": {
          "idea": { "type": "string" },
          "category": { "enum": ["experiment_only_fix", "low_risk_extension", "medium_risk_method_change", "high_risk_research_direction"] },
          "targets_claim": { "type": "string" },
          "motivation": { "type": "string" },
          "expected_benefit": { "type": "string" },
          "risk": { "type": "string" },
          "experiment_to_validate": { "type": "string" },
          "evidence_basis": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "proposed_experiments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "proposed_experiment", "metrics"],
        "properties": {
          "claim_id": { "type": "string" },
          "missing_or_weak_evidence": { "type": "string" },
          "proposed_experiment": { "type": "string" },
          "control_baselines": { "type": "array", "items": { "type": "string" } },
          "datasets": { "type": "array", "items": { "type": "string" } },
          "metrics": { "type": "array", "items": { "type": "string" } },
          "expected_observation": { "type": "string" },
          "failure_interpretation": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "related_papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "relation_type", "read_depth", "similarity_summary"],
        "properties": {
          "title": { "type": "string" },
          "relation_type": { "enum": ["baseline_in_experiments", "similar_innovation", "transfer_candidate"] },
          "read_depth": { "enum": ["full_read", "targeted_read", "metadata_only"] },
          "similarity_summary": { "type": "string" },
          "similarity_level": { "enum": ["high", "medium", "low", "unclear"] },
          "local_match_status": { "enum": ["matched", "not_found", "downloaded", "not_checked"] },
          "local_path": { "type": ["string", "null"] },
          "used_for_claims": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "validation": {
      "type": "object",
      "required": ["language", "status", "warnings"],
      "properties": {
        "language": { "const": "zh-CN" },
        "status": { "enum": ["PASS", "WARN", "FAIL"] },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "missing_sections": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
